# ── Copy this file to ".env" and fill in your own keys. Never commit ".env". ──

# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps → Google Cloud Console → Maps JavaScript API key
# (Restrict it to your Netlify domain once deployed.)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# Web push (proximity alerts). Generate a VAPID key pair (see README) and put the
# PUBLIC half here. The private half goes in Supabase secrets, never in the app.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Default territory when someone hits the bare domain with no /territory in the URL.
# Matches a tenants.slug row. The URL path (e.g. /ph) overrides this per visit.
VITE_TENANT_SLUG=ph

# Staging only: set to 1 to unlock every screen (no login) at /preview.
# Leave blank / remove for production so the app re-locks behind auth.
VITE_PREVIEW_MODE=1

# ── Server-side secrets — set these in Supabase, NOT here (never in the app) ──
# Event booking → GHL/LeadConnector:
#   GHL_API_TOKEN, GHL_LOCATION_ID, GHL_PIPELINE_ID, GHL_PIPELINE_STAGE_ID
# "On the way" text → Twilio:
#   TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
# Shared:
#   APP_BASE_URL=https://donutnvapp.com   (used to build tracking links)
# Set with:  supabase secrets set GHL_API_TOKEN=... (see README → Event booking)
